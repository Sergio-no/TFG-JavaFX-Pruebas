<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.example.tfgjavafxpruebas.controller.LoginController"
           styleClass="bg-primary"
           prefWidth="1100" prefHeight="700">

    <!-- Columna centrada -->
    <VBox alignment="CENTER" spacing="0" maxWidth="380">

        <!-- Logo / título -->
        <VBox alignment="CENTER" spacing="6" style="-fx-padding: 0 0 36 0;">
            <Label text="AutoElite" style="-fx-font-size: 28px; -fx-font-weight: 500;"
                   styleClass="text-blue"/>
            <Label text="Sistema de gestión de taller"
                   styleClass="text-muted"
                   style="-fx-font-size: 13px;"/>
        </VBox>

        <!-- Card del formulario -->
        <VBox styleClass="card" spacing="16" style="-fx-padding: 32;">

            <Label text="Iniciar sesión"
                   styleClass="text-primary"
                   style="-fx-font-size: 16px; -fx-font-weight: 500;"/>

            <!-- Email -->
            <VBox spacing="6">
                <Label text="Email" styleClass="text-muted" style="-fx-font-size: 12px;"/>
                <TextField fx:id="emailField"
                           promptText="usuario@autoelite.com"
                           styleClass="input-field"/>
            </VBox>

            <!-- Contraseña -->
            <VBox spacing="6">
                <Label text="Contraseña" styleClass="text-muted" style="-fx-font-size: 12px;"/>
                <PasswordField fx:id="passwordField"
                               promptText="••••••••"
                               styleClass="input-field"/>
            </VBox>

            <!-- Error -->
            <Label fx:id="errorLabel" styleClass="label-error" text="" wrapText="true"/>

            <!-- Botón -->
            <Button fx:id="loginButton"
                    text="Entrar"
                    styleClass="btn-primary"
                    maxWidth="Infinity"
                    onAction="#handleLogin"/>

            <!-- Loading indicator -->
            <ProgressIndicator fx:id="loadingIndicator"
                               visible="false"
                               prefHeight="24" prefWidth="24"
                               style="-fx-progress-color: #7ec8e3;"
                               HBox.hgrow="ALWAYS"/>

        </VBox>

        <!-- Footer -->
        <Label text="AutoElite · Gestión de talleres v1.0"
               styleClass="text-hint"
               style="-fx-font-size: 11px; -fx-padding: 20 0 0 0;"/>

    </VBox>
</StackPane>
