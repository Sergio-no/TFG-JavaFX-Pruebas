<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.tfgjavafxpruebas.controller.EmpleadosController"
            styleClass="bg-primary" prefWidth="1200" prefHeight="760">
    <left><fx:include source="sidebar.fxml"/></left>
    <center>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-padding:12 20; -fx-background-color:#1a1d23;
                         -fx-border-color:#2e333d; -fx-border-width:0 0 1 0;">
                <Label text="Empleados" styleClass="text-primary"
                       style="-fx-font-size:15px; -fx-font-weight:500;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Desactivar" styleClass="btn-secondary"
                        onAction="#desactivarEmpleado"/>
                <Button text="+ Nuevo empleado" styleClass="btn-primary"
                        onAction="#abrirNuevoEmpleado"/>
            </HBox>
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background:#1e2128; -fx-background-color:#1e2128;">
                <VBox style="-fx-padding:16 20;">
                    <TableView fx:id="empleadosTable" styleClass="table-view">
                        <columns>
                            <TableColumn fx:id="colId"       text="ID"       prefWidth="60"/>
                            <TableColumn fx:id="colNombre"   text="Nombre"   prefWidth="200"/>
                            <TableColumn fx:id="colEmail"    text="Email"    prefWidth="220"/>
                            <TableColumn fx:id="colTelefono" text="Teléfono" prefWidth="130"/>
                            <TableColumn fx:id="colRol"      text="Rol"      prefWidth="100"/>
                            <TableColumn fx:id="colEstado"   text="Estado"   prefWidth="100"/>
                        </columns>
                        <placeholder>
                            <Label text="No hay empleados registrados" styleClass="text-hint"/>
                        </placeholder>
                    </TableView>
                </VBox>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
